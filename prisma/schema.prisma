// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Analysis {
  id             String     @id @default(cuid())
  type           String     // "PF" | "PJ"
  score          Int
  decision       String     // "APROVADO" | "APROVADO_COM_LIMITE" | "ANALISE_MANUAL" | "RECUSADO"
  limiteSugerido Float?
  scoreBreakdown Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  clientPF       ClientPF?
  clientPJ       ClientPJ?
  scoreLogs      ScoreLog[]

  @@map("analyses")
}

model ClientPF {
  id           String   @id @default(cuid())
  analysisId   String   @unique
  analysis     Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  nome         String
  cpf          String
  rendaMensal  Float
  valorParcela Float
  cep          String
  idade        Int
  profissao    String
  createdAt    DateTime @default(now())

  @@map("clients_pf")
}

model ClientPJ {
  id                String   @id @default(cuid())
  analysisId        String   @unique
  analysis          Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  razaoSocial       String
  cnpj              String
  faturamentoMensal Float
  valorParcela      Float
  cep               String
  tempoEmpresaMeses Int
  createdAt         DateTime @default(now())

  @@map("clients_pj")
}

model ScoreLog {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  category   String
  points     Int
  reason     String
  createdAt  DateTime @default(now())

  @@map("score_logs")
}

model ApiSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // AES-256-CBC encrypted
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("api_settings")
}
